# football-data.org API key (free tier, read-only)
VITE_FOOTBALL_API_KEY=

# Supabase project URL
VITE_SUPABASE_URL=

# Supabase anon/public key (safe for client-side use; RLS enforces data access)
VITE_SUPABASE_ANON_KEY=

# OneSignal Web App ID (safe for client-side use)
# Obtain from: OneSignal dashboard → your app → Keys & IDs → App ID
VITE_ONESIGNAL_APP_ID=

# --- SERVER-SIDE ONLY (Netlify Function environment variables) ---
# Never expose these in client code or .env files committed to the repo

# OneSignal REST API Key
# Obtain from: OneSignal dashboard → Settings → Keys & IDs → REST API Key
# Set in: Netlify dashboard → Site → Environment Variables
ONESIGNAL_REST_API_KEY=

# Supabase service role key (bypasses RLS — server-side only)
# Obtain from: Supabase dashboard → Project Settings → API → service_role
# Set in: Netlify dashboard → Site → Environment Variables
SUPABASE_SERVICE_ROLE_KEY=
