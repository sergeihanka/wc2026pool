# football-data.org API key (free tier, read-only)
VITE_FOOTBALL_API_KEY=

# football-data.org API base URL (non-secret; default https://api.football-data.org/v4)
# Override only if you need to point at a different environment (e.g. a mock server)
VITE_FOOTBALL_API_BASE_URL=

# Supabase project URL
VITE_SUPABASE_URL=

# Supabase anon/public key (safe for client-side use; RLS enforces data access)
VITE_SUPABASE_ANON_KEY=

# OneSignal Web App ID (safe for client-side use)
# Obtain from: OneSignal dashboard → your app → Keys & IDs → App ID
VITE_ONESIGNAL_APP_ID=

# --- SERVER-SIDE ONLY (Netlify Function environment variables) ---
# Never expose these in client code or .env files committed to the repo

# OneSignal REST API Key
# Obtain from: OneSignal dashboard → Settings → Keys & IDs → REST API Key
# Set in: Netlify dashboard → Site → Environment Variables
ONESIGNAL_REST_API_KEY=

# Supabase service role key (bypasses RLS — server-side only)
# Obtain from: Supabase dashboard → Project Settings → API → service_role
# Set in: Netlify dashboard → Site → Environment Variables
SUPABASE_SERVICE_ROLE_KEY=

# Supabase database password (the "postgres" user password, set at project creation)
# Obtain from: Supabase dashboard → Project Settings → Database → Connection string
# Used by: supabase/apply-migrations.mjs and the Supabase CLI (supabase db push --password)
# LOCAL ONLY — never set in Netlify or any deployed environment
SUPABASE_DB_PASSWORD=

# Supabase personal access token (your dashboard user token, not project-scoped)
# Generate at: https://supabase.com/dashboard/account/tokens
# Used by: supabase CLI (supabase link, supabase db push --linked) and apply-migrations.mjs
# LOCAL ONLY — never deploy this token
SUPABASE_ACCESS_TOKEN=
